# PrepForAll — API Server Environment Variables
# Copy this file to .env and fill in your values (for local dev only)
# Production secrets are managed via AWS SSM Parameter Store

# ── Server ────────────────────────────────────────────────────────────────────
ENV=development
PORT=8080

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Default matches docker-compose.yml credentials
DATABASE_URL=postgres://prepforall:devpassword@localhost:5432/prepforall?sslmode=disable

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters — change this before sharing or deploying
JWT_SECRET=dev-secret-min-32-characters-long-ok
JWT_EXPIRY=24h

# ── AWS / S3 ──────────────────────────────────────────────────────────────────
# For local dev you can use LocalStack or leave blank if not testing uploads
AWS_REGION=ap-south-1
S3_BUCKET=prepforall-dev

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000"]
