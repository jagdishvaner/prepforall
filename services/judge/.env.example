# PrepForAll — Judge Worker Environment Variables
# Copy this file to .env and fill in your values (for local dev only)

# ── Redis ─────────────────────────────────────────────────────────────────────
# Must match the REDIS_ADDR used by the API server
REDIS_ADDR=localhost:6379

# ── Judge ─────────────────────────────────────────────────────────────────────
# Number of concurrent sandbox workers
JUDGE_WORKERS=2

# Docker image used for sandboxed execution
# Build with: make build-sandbox-images
DOCKER_IMAGE=prepforall-sandbox:latest
